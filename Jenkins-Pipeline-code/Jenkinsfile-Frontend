pipeline {
    agent {
       label 'jenkins-agent'
}
    tools {
        jdk 'jdk21'
        nodejs 'NodeJS18'
    }
    environment  {
        SCANNER_HOME=tool 'SonarScanner'
        AWS_ACCOUNT_ID = '910972978008'
        AWS_ECR_REPO_NAME = 'client'
        AWS_DEFAULT_REGION = 'ap-south-1'
        REPOSITORY_URI = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
}
    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Checkout from Git') {
            steps {
                git branch: 'main', url: 'https://github.com/Divya-CloudDevOps/AWS-Microservices-project-2026.git'
            }
        }
        stage('Sonarqube Analysis') {
            steps {
                dir('client') {
                    withSonarQubeEnv('sonarqube') {
                        sh ''' $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=three-tier-frontend \
                        -Dsonar.projectKey=three-tier-frontend '''
                    }
                }
            }
        }
        stage('Quality Check') {
            steps {
                script {
                    waitForQualityGate abortPipeline: false 
                }
            }
        }
        stage('Trivy File Scan') {
            steps {
                dir('client') {
                    sh 'trivy fs . > trivyfs.txt'
                }
            }
        }
        stage("Docker Image Build") {
            steps {
                script {
                    dir('client') {
                            sh 'docker system prune -f'
                            sh 'docker build -t client:${BUILD_NUMBER} .'
                   }
                }
            }
        }
        stage("ECR Image Pushing") {
            steps {
                script {
                        sh 'aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 910972978008.dkr.ecr.ap-south-1.amazonaws.com'
                        sh 'docker tag client:${BUILD_NUMBER} ${REPOSITORY_URI}/client:${BUILD_NUMBER}'
                        sh 'docker push ${REPOSITORY_URI}/client:${BUILD_NUMBER}'               
                 }
            }
        }
        stage("TRIVY Image Scan") {
            steps {
                sh """
                trivy image ${REPOSITORY_URI}/client:${BUILD_NUMBER}  > trivyimage.txt
                """
           }
        }
        
        stage('Update Deployment file') {
            environment {
                GIT_REPO_NAME = "AWS-Microservices-project-2026"
                GIT_USER_NAME = "Divya-CloudDevOps"
            }
            steps {
                dir('kubernetes-files') {
                    withCredentials([string(credentialsId: 'Jenkins-GitHub-Token', variable: 'git_token')]) {
                        sh '''
                            git config user.email "usercloud003@gmail.com"
                            git config user.name "Divya-CloudDevOps"
                            BUILD_NUMBER=${BUILD_NUMBER}
                            echo $BUILD_NUMBER
                            sed -i "s#image:.*#image: ${REPOSITORY_URI}/${AWS_ECR_REPO_NAME}:${BUILD_NUMBER}#g" frontend-deploy-service.yaml
                            git add .
                            git diff --cached --quiet || git commit -m "Update deployment Image to version \${BUILD_NUMBER}"
                            git push https://${git_token}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
        
                        '''
                    }
                }
            }
        }
    }
}
